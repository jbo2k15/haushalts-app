generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  passwordHash       String
  name               String
  role               String               @default("user")
  approved           Boolean              @default(false)
  mustChangePassword Boolean              @default(false)
  vacationMode       Boolean              @default(false)
  lastActiveAt       DateTime?
  dayTrophies        Int                  @default(0)
  weekTrophies       Int                  @default(0)
  monthTrophies      Int                  @default(0)
  createdAt          DateTime             @default(now())
  pushSubscriptions  PushSubscription[]
  notificationSettings NotificationSettings?
  taskCompletions    TaskCompletion[]
  taskLogs           TaskLog[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens      RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id                    String  @id @default(uuid())
  userId                String? @unique
  dailyTime             String  @default("21:00")
  weeklyDay             Int     @default(6)
  weeklyTime            String  @default("09:00")
  lastDailyNotifiedDate String?
  lastWeeklyNotifiedDate String?
  user                  User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id               String           @id @default(uuid())
  title            String
  type             String
  priority         String           @default("normal")
  weekdays         String?
  fixedWeekday     Int?
  fixedDayOfMonth  Int?
  dueDate          String?
  sortOrder        Int              @default(0)
  isActive         Boolean          @default(true)
  isAutoGenerated  Boolean          @default(false)
  allowMultiple    Boolean          @default(false)
  createdAt        DateTime         @default(now())
  completions      TaskCompletion[]
  logs             TaskLog[]
}

model TaskCompletion {
  id          String    @id @default(uuid())
  taskId      String
  completedBy String?
  completedAt DateTime  @default(now())
  forDate     String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [completedBy], references: [id], onDelete: SetNull)
  logs        TaskLog[]

  // No longer @@unique: daily tasks can be completed multiple times per day
  // (see /complete route — non-daily types still enforce single-completion
  // semantics at the application level via findFirst-before-create).
  @@index([taskId, forDate])
  @@index([completedBy])
}

model TaskLog {
  id           String          @id @default(uuid())
  taskId       String?
  taskTitle    String
  status       String
  completedBy  String?
  userName     String?
  loggedAt     DateTime        @default(now())
  forDate      String
  completionId String?
  task         Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user         User?           @relation(fields: [completedBy], references: [id], onDelete: SetNull)
  completion   TaskCompletion? @relation(fields: [completionId], references: [id], onDelete: Cascade)

  @@index([completedBy, status, forDate])
  @@index([loggedAt])
  @@index([taskId, forDate, status])
}
